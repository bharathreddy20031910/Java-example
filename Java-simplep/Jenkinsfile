pipeline{
    agent any
    tools{
        maven 'Maven'
    }
    stages{

        stage('Checkout'){
            steps{
                echo 'Checking out...'
                git url: 'https://github.com/bharathreddy20031910/Java-example.git' , branch: 'main'

                }
        }
        stage('Build'){
            steps{
                dir('Java-simplep'){
                     echo 'Building...'
                sh 'mvn clean package'
                }
               
            }
        }
        stage('Test'){
            steps{
                echo 'Testing...'
                sh 'mvn test'
            }
        }
        stage('Deploy'){
            steps{
                echo 'Deploying...'
            }
        }
    }
}